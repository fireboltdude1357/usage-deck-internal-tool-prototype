# Local dev defaults. Copy to .env and adjust.
# Phase 01: bypass auth so the dashboard renders against fixtures.
AUTH_BYPASS=1

# fixtures | s3. Local dev keeps `fixtures` (no AWS creds needed).
# Vercel Production runs with `s3` — `/api/snapshot/*` reads via AWS SDK
# from `s3://${SNAPSHOT_BUCKET}/...`. See src/lib/server/snapshot-source.ts.
SNAPSHOT_SOURCE=fixtures

# Phase 02 — PostHog API.
POSTHOG_API_KEY=

# SNAPSHOT_AWS_* / SNAPSHOT_BUCKET feed two consumers:
#  - phase 03 writer (scripts/snapshot/upload.ts) — local monthly export.
#  - phase 04 reader (src/lib/server/snapshot-source.ts) — Vercel Production
#    server-side read when SNAPSHOT_SOURCE=s3.
# Tanner's IAM is the prototype identity for both; phase 05 splits to a
# dedicated read-only principal scoped to internal-tool-snapshots/*.
SNAPSHOT_AWS_ACCESS_KEY_ID=
SNAPSHOT_AWS_SECRET_ACCESS_KEY=
SNAPSHOT_AWS_REGION=us-east-1
SNAPSHOT_BUCKET=internal-tool-snapshots

# Phase 03 — RDS query runner (scripts/snapshot/query.ts).
# Same env-var contract as parent-db-investigations rds-query skill so existing
# creds work. RDS_INSTANCE defaults to "staging"; legacy unprefixed RDS_* is
# also accepted for staging.
RDS_INSTANCE=staging
RDS_STAGING_HOST=
RDS_STAGING_USER=
RDS_STAGING_PASSWORD=
RDS_STAGING_PORT=5432
RDS_STAGING_SSLMODE=verify-full
RDS_STAGING_SSL_ROOT_CERT=
RDS_STAGING_BASTION_HOST=
RDS_STAGING_BASTION_USER=ec2-user
RDS_STAGING_BASTION_KEY_PATH=

# Phase 05 — WorkOS SSO.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=
WORKOS_COOKIE_PASSWORD=
